APP_NAME=telegram-community-logger
ENVIRONMENT=local
LOG_LEVEL=INFO

# Telegram
TELEGRAM_BOT_TOKEN=123456:replace-me
TELEGRAM_WEBHOOK_SECRET_TOKEN=replace-with-at-least-16-random-chars
TELEGRAM_BOT_USER_ID=
TELEGRAM_CHANNEL_CHAT_ID=-1001111111111
TELEGRAM_DISCUSSION_GROUP_CHAT_ID=-1002222222222
TELEGRAM_SUPPORT_GROUP_CHAT_ID=-1003333333333
TELEGRAM_SUPPORT_ADMIN_USER_IDS=11111111,22222222
TELEGRAM_ACCEPT_UNMAPPED_DISCUSSION_THREADS=false

# SQLite
SQLITE_PATH=data/app.db

# Google Sheets
# Local file mode.
GOOGLE_CREDENTIALS_PATH=secrets/google-service-account.json
# Render-friendly secret env mode. Leave empty locally if using GOOGLE_CREDENTIALS_PATH.
GOOGLE_CREDENTIALS_JSON=
GOOGLE_SPREADSHEET_ID=replace-spreadsheet-id
GOOGLE_MESSAGES_SHEET_NAME=Messages
GOOGLE_APPEND_RANGE=Messages!A:W
GOOGLE_REQUEST_TIMEOUT_SECONDS=30

# Sync
SYNC_BATCH_SIZE=50
SYNC_ON_INGEST=true

# Temporary load-shedding switches
DIRECT_BROADCAST_ENABLED=false
TICKET_ALERTS_ENABLED=false
